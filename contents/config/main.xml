<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
  <kcfgfile name=""/>

  <!--
    IMPORTANT: All entries MUST stay in the single "General" group.
    KDE persists settings as [Configuration][General][key] in appletsrc.
    Moving entries to a different group name changes the storage path and
    causes all existing user settings to be silently dropped (reset to defaults).
  -->
  <group name="General">

    <!-- ── Location ──────────────────────────────────────────────────── -->
    <entry name="autoDetectLocation" type="Bool"><default>false</default></entry>
    <entry name="locationName"       type="String"><default></default></entry>
    <entry name="latitude"           type="Double"><default>0.0</default></entry>
    <entry name="longitude"          type="Double"><default>0.0</default></entry>
    <entry name="altitude"           type="Int"><default>0</default></entry>
    <entry name="timezone"           type="String"><default></default></entry>
    <entry name="countryCode"        type="String"><default></default></entry>
    <!-- Single-write active location: JSON {name,lat,lon,altitude,timezone,countryCode}.
         Written atomically by applyLocation() to avoid 6 separate config-change signals. -->
    <entry name="activeLocation"     type="String"><default>{}</default></entry>
    <entry name="weatherProvider"    type="String"><default>adaptive</default></entry>
    <!-- Saved locations: JSON array of {name, lat, lon, altitude, timezone, countryCode} -->
    <entry name="savedLocations"     type="String"><default>[]</default></entry>
    <!-- User API keys -->
    <entry name="owApiKey"           type="String"><default></default></entry>
    <entry name="waApiKey"           type="String"><default></default></entry>
    <entry name="pwApiKey"           type="String"><default></default></entry>
    <entry name="vcApiKey"           type="String"><default></default></entry>
    <entry name="tioApiKey"          type="String"><default></default></entry>
    <entry name="sgApiKey"           type="String"><default></default></entry>
    <entry name="wbApiKey"           type="String"><default></default></entry>
    <entry name="qwApiKey"           type="String"><default></default></entry>
    <entry name="qwApiHost"          type="String"><default></default></entry>

    <!-- ── Behaviour ─────────────────────────────────────────────────── -->
    <entry name="keepOpen"           type="Bool"><default>false</default></entry>

    <!-- ── Units ─────────────────────────────────────────────────────── -->
    <!-- unitsMode: "metric" | "imperial" | "kde" | "custom" -->
    <entry name="unitsMode"               type="String"><default>kde</default></entry>
    <entry name="temperatureUnit"         type="String"><default>C</default></entry>
    <entry name="pressureUnit"            type="String"><default>hPa</default></entry>
    <entry name="windSpeedUnit"           type="String"><default>kmh</default></entry>
    <entry name="precipitationUnit"       type="String"><default>mm</default></entry>
    <entry name="altitudeUnit"            type="String"><default>m</default></entry>
    <entry name="apparentTemperatureMode" type="String"><default>apparent</default></entry>
    <entry name="roundValues"             type="Bool"><default>true</default></entry>
    <entry name="showTempUnit"             type="Bool"><default>false</default></entry>

    <!-- ── Panel — layout and items ──────────────────────────────────── -->
    <!-- panelInfoMode: "single" | "multiline" | "simple" -->
    <entry name="panelInfoMode"    type="String"><default>simple</default></entry>
    <entry name="panelItemOrder"   type="String"><default>location;temperature;humidity</default></entry>
    <entry name="panelItemIcons"   type="String"><default>location=1;condition=1;temperature=1;suntimes=1;wind=1;feelslike=1;humidity=1;pressure=1;moonphase=1;preciprate=1;uvindex=1;airquality=1;spaceweather=1;alerts=1;snowcover=1</default></entry>
    <entry name="panelSeparator"   type="String"><default> • </default></entry>
    <entry name="panelItemSpacing" type="Int"><default>5</default><min>0</min><max>32</max></entry>
    <entry name="panelFillWidth"   type="Bool"><default>false</default></entry>
    <entry name="panelSunTimesMode" type="String"><default>upcoming</default></entry>
    <entry name="panelMoonPhaseMode" type="String"><default>full</default></entry>
    <entry name="panelWidth"       type="Int"><default>0</default></entry>
    <!-- Legacy panel booleans (superseded by panelItemOrder; kept for back-compat) -->
    <entry name="panelShowTemperature" type="Bool"><default>true</default></entry>
    <entry name="panelShowWeatherIcon" type="Bool"><default>false</default></entry>
    <entry name="panelShowSunTimes"    type="Bool"><default>false</default></entry>
    <entry name="panelShowWind"        type="Bool"><default>false</default></entry>
    <entry name="panelShowFeelsLike"   type="Bool"><default>false</default></entry>
    <entry name="panelShowHumidity"    type="Bool"><default>true</default></entry>
    <entry name="panelShowPressure"    type="Bool"><default>false</default></entry>
    <entry name="panelShowCondition"   type="Bool"><default>false</default></entry>
    <entry name="panelShowLocation"    type="Bool"><default>true</default></entry>

    <!-- ── Panel — multiline mode ─────────────────────────────────────── -->
    <entry name="panelMultiLines"         type="Int"><default>2</default><min>1</min><max>8</max></entry>
    <entry name="panelMultiAnimate"       type="Bool"><default>true</default></entry>
    <entry name="panelMultilineIconStyle" type="String"><default>colorful</default></entry>
    <entry name="panelMultilineIconSize"  type="Int"><default>0</default></entry>
    <entry name="panelScrollSeconds"      type="Int"><default>4</default><min>1</min><max>30</max></entry>

    <!-- ── Panel — simple mode ───────────────────────────────────────── -->
    <entry name="panelSimpleLayoutType"        type="Int"><default>0</default></entry>
    <entry name="panelSimpleWidgetOrder"       type="Int"><default>0</default></entry>
    <entry name="panelSimpleIconStyle"         type="String"><default>symbolic</default></entry>
    <entry name="panelSimpleHorizontalContent" type="String"><default>both</default></entry>
    <entry name="panelSimpleClickAreaMode"     type="String"><default>auto</default></entry>
    <entry name="panelSimpleClickAreaSize"     type="Int"><default>96</default><min>20</min><max>600</max></entry>
    <entry name="panelSimpleTempShadowEnabled" type="Bool"><default>true</default></entry>
    <entry name="panelSimpleTempShadowIntensity" type="Double"><default>0.8</default></entry>
    <entry name="panelSimpleTempShadowColor" type="String"><default></default></entry>
    <entry name="simpleTempColor" type="String"><default></default></entry>
    <!-- Compressed mode: badge position, spacing, background color -->
    <entry name="compressedBadgePosition"  type="String"><default>bottom-right</default></entry>
    <entry name="compressedBadgeSpacing"   type="Int"><default>0</default><min>-20</min><max>20</max></entry>
    <entry name="compressedBadgeColor"     type="String"><default></default></entry>
    <entry name="compressedBadgeOpacity"   type="Double"><default>0.85</default></entry>
    <!-- System tray uses fixed Simple + Compressed layout, with its own appearance knobs. -->
    <entry name="traySimpleIconStyle"       type="String"><default>symbolic</default></entry>
    <entry name="trayCompressedBadgePosition" type="String"><default>bottom-right</default></entry>
    <entry name="trayCompressedBadgeSpacing"  type="Int"><default>0</default><min>-20</min><max>20</max></entry>
    <entry name="trayCompressedBadgeColor"    type="String"><default></default></entry>
    <entry name="trayCompressedBadgeOpacity"  type="Double"><default>0.85</default></entry>
    <entry name="simpleIconSizeMode"    type="String"><default>auto</default></entry>
    <entry name="simpleIconSizeManual"  type="Int"><default>32</default><min>16</min><max>72</max></entry>
    <entry name="simpleFontSizeMode"    type="String"><default>auto</default></entry>
    <entry name="simpleFontSizeManual"  type="Int"><default>14</default><min>8</min><max>48</max></entry>
    <!-- Live auto-computed px values written by CompactView; read-only in config -->
    <entry name="simpleIconAutoSz"      type="Int"><default>0</default></entry>
    <entry name="simpleFontAutoSz"      type="Int"><default>0</default></entry>
    <entry name="simplePanelDim"        type="Int"><default>48</default></entry>
    <entry name="simplePanelIsVertical" type="Bool"><default>false</default></entry>

    <!-- ── Panel — icons and font ─────────────────────────────────────── -->
    <!-- panelIconTheme: "symbolic" | "wi-font" | "flat-color" | "3d-oxygen" | "3d-adwaita" | "kde" | "custom" -->
    <entry name="panelIconTheme"       type="String"><default>symbolic</default></entry>
    <entry name="panelIconSize"        type="Int"><default>22</default></entry>
    <entry name="panelIconSizeMode"    type="String"><default>auto</default></entry>
    <entry name="panelIconSizeManual"  type="Int"><default>22</default><min>12</min><max>48</max></entry>
    <entry name="panelSymbolicVariant" type="String"><default>dark</default></entry>
    <entry name="panelCustomIcons"     type="String"><default></default></entry>
    <entry name="panelUseSystemFont"   type="Bool"><default>true</default></entry>
    <entry name="panelFontFamily"      type="String"><default></default></entry>
    <entry name="panelFontSize"        type="Int"><default>11</default><min>7</min><max>24</max></entry>
    <entry name="panelFontBold"        type="Bool"><default>false</default></entry>

    <!-- ── Widget popup ───────────────────────────────────────────────── -->
    <!-- widgetWidth/Height: 0 = use built-in default (540 × 550) -->
    <entry name="widgetWidth"      type="Int"><default>0</default></entry>
    <entry name="widgetHeight"     type="Int"><default>0</default></entry>
    <!-- Minimum popup size: "auto" = 750, "manual" = user-set -->
    <entry name="widgetMinWidthMode"  type="String"><default>auto</default></entry>
    <entry name="widgetMinWidth"      type="Int"><default>750</default><min>200</min><max>2000</max></entry>
    <entry name="widgetMinHeightMode" type="String"><default>auto</default></entry>
    <entry name="widgetMinHeight"     type="Int"><default>750</default><min>200</min><max>2000</max></entry>
    <entry name="widgetDefaultTab" type="String"><default>details</default></entry>
    <entry name="widgetVisibleTabs" type="String"><default>both</default></entry>
    <entry name="widgetLayoutMode"      type="String"><default>advanced</default></entry>
    <entry name="widgetSimpleDetailsOrder" type="String"><default>humidity;pressure;preciprate;precipsum</default></entry>
    <entry name="widgetSimpleDetailsItemIcons" type="String"><default>humidity=1;pressure=1;preciprate=1;precipsum=1</default></entry>
    <entry name="radarEnabled"          type="Bool"><default>true</default></entry>
    <entry name="radarLayer"            type="String"><default>rainviewer</default></entry>
    <entry name="radarZoom"             type="Int"><default>9</default><min>3</min><max>18</max></entry>

    <!-- ── Widget — details view ──────────────────────────────────────── -->
    <entry name="widgetDetailsOrder"    type="String"><default>humidity;pressure;wind;dewpoint;visibility;precipsum;moonphase;suntimes;preciprate;uvindex;airquality;pollen;spaceweather;alerts;datetime;snowcover</default></entry>
    <entry name="widgetDetailsItemIcons" type="String"><default>humidity=1;pressure=1;wind=1;preciprate=1;suntimes=1;dewpoint=1;visibility=1;moonphase=1;uvindex=1;airquality=1;spaceweather=1;alerts=1;datetime=1;pollen=1;snowcover=1</default></entry>
    <entry name="widgetDetailsCustomIcons" type="String"><default></default></entry>
    <entry name="widgetDetailsLayout"   type="String"><default>cards2</default></entry>
    <entry name="widgetSunTimesMode"    type="String"><default>both</default></entry>
    <entry name="widgetMoonMode"        type="String"><default>full</default></entry>
    <entry name="widgetCardsHeightAuto" type="Bool"><default>true</default></entry>
    <entry name="widgetCardsHeight"     type="Int"><default>44</default><min>30</min><max>120</max></entry>
    <entry name="widgetExpandedCardsHeightAuto" type="Bool"><default>false</default></entry>
    <entry name="widgetExpandedCardsHeight"     type="Int"><default>200</default><min>120</min><max>500</max></entry>
    <!-- Expanded view items visibility (comma-separated) -->
    <entry name="aqiExpandedItems"          type="String"><default>pm2_5,pm10,no2,o3,so2,co</default></entry>
    <entry name="pollenExpandedItems"       type="String"><default>alder,birch,grass,mugwort,olive,ragweed</default></entry>
    <entry name="spaceWeatherExpandedItems" type="String"><default>gscale,kp,solarwind,aurora,bz,xray</default></entry>
    <!-- Legacy details booleans (superseded by widgetDetailsOrder; kept for back-compat) -->
    <entry name="widgetShowFeelsLike"   type="Bool"><default>true</default></entry>
    <entry name="widgetShowHumidity"    type="Bool"><default>true</default></entry>
    <entry name="widgetShowPressure"    type="Bool"><default>true</default></entry>
    <entry name="widgetShowWind"        type="Bool"><default>true</default></entry>
    <entry name="widgetShowSunrise"     type="Bool"><default>true</default></entry>
    <entry name="widgetShowDewPoint"    type="Bool"><default>true</default></entry>
    <entry name="widgetShowVisibility"  type="Bool"><default>true</default></entry>

    <!-- ── Widget — icons and font ────────────────────────────────────── -->
    <!-- widgetIconTheme: "symbolic" | "wi-font" | "flat-color" | "3d-oxygen" | "kde" -->
    <entry name="widgetIconTheme" type="String"><default>symbolic</default></entry>
    <!-- conditionIconTheme: "kde" | "kde-symbolic" | "symbolic" | "flat-color" | "3d-oxygen" | "custom" -->
    <entry name="conditionIconTheme" type="String"><default>kde</default></entry>
    <entry name="widgetConditionCustomIcons" type="String"><default></default></entry>
    <entry name="widgetIconSize"  type="Int"><default>32</default></entry>
    <entry name="useSystemFont"   type="Bool"><default>true</default></entry>
    <entry name="fontFamily"      type="String"><default>Noto Sans</default></entry>
    <entry name="fontSize"        type="Int"><default>11</default><min>7</min><max>24</max></entry>
    <entry name="fontBold"        type="Bool"><default>false</default></entry>

    <!-- ── Calendar first day of week (-1 = region default, 0=Sun, 1=Mon, 5=Fri, 6=Sat) -->
    <entry name="calendarFirstDayOfWeek" type="Int"><default>-1</default></entry>

    <!-- ── Item date/time formats ───────────────────────────────────── -->
    <entry name="panelDateTimeFormat"    type="String"><default>locale-short</default></entry>
    <entry name="panelTimeFormat"        type="String"><default>locale</default></entry>
    <entry name="detailsDateTimeFormat"  type="String"><default>locale-long</default></entry>
    <entry name="detailsTimeFormat"      type="String"><default>locale</default></entry>
    <entry name="tooltipDateTimeFormat"  type="String"><default>locale-long</default></entry>
    <entry name="tooltipTimeFormat"      type="String"><default>locale</default></entry>

    <!-- ── Dual temperature display ─────────────────────────────────── -->
    <entry name="dualTempEnabled"    type="Bool"><default>false</default></entry>
    <entry name="dualTempSeparator"  type="String"><default> / </default></entry>
    <entry name="dualTempInWidget"   type="Bool"><default>true</default></entry>
    <entry name="dualTempInPanel"    type="Bool"><default>true</default></entry>
    <entry name="dualTempInTooltip"  type="Bool"><default>true</default></entry>
    <entry name="dualTempSwapOrder"  type="Bool"><default>false</default></entry>

    <!-- ── Widget — header date/time ─────────────────────────────────── -->
    <entry name="headerShowDateTime" type="Bool"><default>false</default></entry>
    <entry name="headerDateFormat"   type="String"><default>locale-long</default></entry>
    <entry name="headerTimeFormat"   type="String"><default>locale</default></entry>

    <!-- ── Widget — simple mode options ──────────────────────────────── -->
    <entry name="simpleShowForecast"     type="Bool"><default>true</default></entry>
    <entry name="simpleShowSunriseSunset" type="Bool"><default>true</default></entry>
    <entry name="simpleShowForecastCompass" type="Bool"><default>true</default></entry>
    <entry name="simpleShowStatsChips"   type="Bool"><default>true</default></entry>

    <!-- ── Widget — forecast ──────────────────────────────────────────── -->
    <entry name="forecastLayout"      type="String"><default>rows</default></entry>
    <entry name="forecastDays"        type="Int"><default>5</default><min>3</min><max>16</max></entry>
    <entry name="forecastIconTheme"   type="String"><default>symbolic</default></entry>
    <entry name="forecastShowSunEvents" type="Bool"><default>true</default></entry>
    <entry name="forecastShowToday"    type="Bool"><default>true</default></entry>
    <entry name="forecastHourlyLayout" type="String"><default>cards</default></entry>
    <entry name="forecastAutoOpen"     type="Bool"><default>true</default></entry>
    <entry name="forecastExpandAll"    type="Bool"><default>false</default></entry>
    <entry name="animateTransitions"  type="Bool"><default>true</default></entry>

    <!-- ── Tooltip ────────────────────────────────────────────────────── -->
    <entry name="tooltipEnabled"    type="Bool"><default>true</default></entry>
    <entry name="tooltipStyle"      type="String"><default>verbose</default></entry>
    <entry name="tooltipItemOrder"  type="String"><default>temperature;wind;humidity;pressure;suntimes</default></entry>
    <entry name="tooltipItemIcons"  type="String"><default>temperature=1;condition=1;feelslike=1;wind=1;humidity=1;pressure=1;suntimes=1;moonphase=1;preciprate=1;uvindex=1;airquality=1;spaceweather=1;alerts=1;snowcover=1</default></entry>
    <entry name="tooltipSunTimesMode" type="String"><default>both</default></entry>
    <entry name="tooltipMoonPhaseMode" type="String"><default>full</default></entry>
    <!-- tooltipIconTheme: "symbolic" | "wi-font" | "flat-color" | "3d-oxygen" | "kde" | "custom" -->
    <entry name="tooltipIconTheme"       type="String"><default>symbolic</default></entry>
    <entry name="tooltipIconSize"        type="Int"><default>22</default></entry>
    <entry name="tooltipSymbolicVariant" type="String"><default>dark</default></entry>
    <entry name="tooltipCustomIcons"     type="String"><default></default></entry>
    <entry name="tooltipUseIcons"        type="Bool"><default>true</default></entry>
    <entry name="tooltipWidthMode"       type="String"><default>auto</default></entry>
    <entry name="tooltipWidthManual"     type="Int"><default>320</default></entry>
    <entry name="tooltipHeightMode"      type="String"><default>auto</default></entry>
    <entry name="tooltipHeightManual"    type="Int"><default>300</default></entry>
    <entry name="tooltipLocationWrap"    type="String"><default>truncate</default></entry>

    <!-- ── General / misc ─────────────────────────────────────────────── -->
    <entry name="refreshIntervalMinutes" type="Int"><default>15</default><min>5</min><max>180</max></entry>
    <entry name="autoRefresh"            type="Bool"><default>true</default></entry>
    <entry name="showUpdateText"         type="Bool"><default>true</default></entry>
    <entry name="singlePanelRow"         type="Bool"><default>true</default></entry>
    <entry name="showScrollbox"          type="Bool"><default>true</default></entry>
    <entry name="scrollboxLines"         type="Int"><default>2</default><min>1</min><max>6</max></entry>
    <entry name="scrollboxItems"         type="String"><default>Humidity;Wind;Pressure;Dew Point;Visibility</default></entry>
    <entry name="panelWidth"             type="Int"><default>0</default></entry>

  </group>
</kcfg>
